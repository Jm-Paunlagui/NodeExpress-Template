# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
USE_HTTPS=false
APP_NAME=MEAL

# ─── Clustering ────────────────────────────────────────────────────────────
ENABLE_CLUSTERING=false
NUM_WORKERS=2

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── CSRF ──────────────────────────────────────────────────────────────────
CSRF_SECRET=your-csrf-secret-key-here-change-in-production

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Cookies ───────────────────────────────────────────────────────────────
COOKIE_SECRET=

# ─── Body Parsing ──────────────────────────────────────────────────────────
BODY_LIMIT=10mb

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
TRUST_PROXY=false

# ─── IP Filtering ──────────────────────────────────────────────────────────
ENABLE_IP_FILTER=false
ALLOWED_IPS=

# ─── Database (Oracle) ─────────────────────────────────────────────────────
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=ORCL

UA_DB_USERNAME=
UA_DB_PASSWORD=

UI_DB_USERNAME=
UI_DB_PASSWORD=

# ─── Database (Test / Dev) ─────────────────────────────────────────────────
DB_TEST_HOST=
DB_TEST_PORT=
DB_TEST_SID=
UI_TEST_DB_USERNAME=
UI_TEST_DB_PASSWORD=

# ─── Oracle Instant Client ─────────────────────────────────────────────────
ORACLE_INSTANT_CLIENT=

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_CONSOLE_LOGS=true
LOG_EXCLUDE_HEALTH=true
LOG_EXCLUDE_URLS=
LOG_MAX_SAFESTR_LENGTH=           # Defaults to Infinity (no truncation). Set a number only if needed.
LOG_CALLSITE=true                 # Capture function/file/line in logs

# ─── Password Hashing ─────────────────────────────────────────────────────
# Set to 'plain' for development/testing or 'bcrypt' for production
PASSWORD_HASH_MODE=bcrypt

# ─── PKG ───────────────────────────────────────────────────────────────────
PFX_PASSPHRASE=                   # Passphrase for PFX certificate (HTTPS)

# ─── Docker ───────────────────────────────────────────────────────────────
DOCKER_CONTAINER=false
